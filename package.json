{
  "name": "tg-bot-menu",
  "version": "1.0.0",
  "description": "A smart Telegram bot for planning daily and weekly meals, managing recipes, and generating shopping lists.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:check": "node scripts/check-db-integrity.js",
    "db:cleanup": "node scripts/cleanup-dangling-refs.js",
    "db:cleanup:dry": "node scripts/cleanup-dangling-refs.js --dry-run",
    "db:cleanup:garbage": "node scripts/delete-test-garbage.js",
    "db:cleanup:garbage:dry": "node scripts/delete-test-garbage.js --dry-run",
    "db:reset": "node scripts/reset-db.js"
  },
  "keywords": [
    "telegram",
    "bot",
    "menu",
    "planning",
    "telegraf",
    "sqlite"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "telegraf": "^4.16.3",
    "sqlite3": "^5.1.7",
    "dotenv": "^16.4.5",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
